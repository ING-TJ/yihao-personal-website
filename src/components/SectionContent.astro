---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import type { LocaleContent } from '@/content/schema';
import { ENABLED_LOCALES, GLOBAL_IDS, HONORS, RESEARCH_IDS, VENTURE_IDS, type Section } from '@/data/site';
import { publications } from '@/data/publications';
import { contact } from '@/data/contact';
import { assetFor, detailRouteFor, routeFor } from '@/utils/routes';
import type { Lang } from '@/data/site';

interface Props { lang: Lang; section: Section; locale: LocaleContent }
const { lang, section, locale } = Astro.props;
const detailPagesEnabled = ENABLED_LOCALES.some((code) => code === lang);
type ContactFieldKey = keyof LocaleContent['contact']['fields'];
type ContactEntry = { key: ContactFieldKey; value: string; href?: string; external?: boolean };
const displayExternalValue = (value: string) => value.replace(/^https?:\/\/(?:www\.)?/i, '').replace(/\/$/, '');
const directContacts = ([
  { key: 'academicEmail', value: contact.academicEmail, href: contact.academicEmail ? `mailto:${contact.academicEmail}` : '' },
  { key: 'companyEmail', value: contact.companyEmail, href: contact.companyEmail ? `mailto:${contact.companyEmail}` : '' },
  { key: 'phone', value: contact.phone, href: contact.phone ? `tel:${contact.phone.replace(/\s+/g, '')}` : '' },
  { key: 'wechat', value: contact.wechat },
  { key: 'instagram', value: contact.instagram, href: contact.instagram, external: true },
  { key: 'linkedin', value: contact.linkedin, href: contact.linkedin, external: true },
  { key: 'github', value: contact.github, href: contact.github, external: true },
  { key: 'orcid', value: contact.orcid, href: contact.orcid, external: true },
  { key: 'researchGate', value: contact.researchGate, href: contact.researchGate, external: true },
] satisfies ContactEntry[]).filter((entry) => Boolean(entry.value));
const contextContacts = ([
  { key: 'institution', value: contact.institution },
  { key: 'location', value: contact.location },
] satisfies ContactEntry[]).filter((entry) => Boolean(entry.value));
const cvDownloads = [
  { key: 'cvEnglish' as const, value: contact.cvEnglish },
  { key: 'cvChinese' as const, value: contact.cvChinese },
].filter((entry) => Boolean(entry.value) && existsSync(join(process.cwd(), 'public', entry.value.replace(/^\//, ''))));
const vcardExists = existsSync(join(process.cwd(), 'public', contact.vcardPath.replace(/^\//, '')));
---
{section === 'about' && (
  <div class="fact-grid">
    {locale.about.map((item, index) => <article class="fact-item"><span class="section-index">0{index + 1}</span><h2>{item.title}</h2><p>{item.body}</p></article>)}
  </div>
)}

{section === 'research' && (
  <div class="research-grid">
    {RESEARCH_IDS.map((id, index) => <article class="research-card"><span class="section-index">R / 0{index + 1}</span><h2>{locale.research[id].title}</h2><p class="research-question">{locale.research[id].question}</p><p class="research-description">{locale.research[id].description}</p>{detailPagesEnabled && <a class="text-link" href={detailRouteFor(lang, 'research', id)}>{locale.common.viewDetails}</a>}</article>)}
  </div>
)}

{section === 'publications' && (
  <section>
    {publications.length > 0 && <ul class="status-pills" aria-label="Publication status filters">{locale.publications.filters.map((filter) => <li>{filter}</li>)}</ul>}
    {publications.length === 0 && <div class="empty-state"><div class="orbital-mark" aria-hidden="true"></div><h2>{locale.publications.emptyTitle}</h2><p>{locale.publications.emptyBody}</p></div>}
  </section>
)}

{section === 'ventures' && (
  <div class="venture-list">
    {VENTURE_IDS.map((id, index) => <article class="venture"><div><span class="section-index">V / 0{index + 1}</span><h2>{locale.ventures[id].title}</h2><p>{locale.ventures[id].descriptor}</p>{detailPagesEnabled && <a class="text-link" href={detailRouteFor(lang, 'ventures', id)}>{locale.common.viewDetails}</a>}</div></article>)}
  </div>
)}

{section === 'honors' && (
  <div class="honors-orbit">
    {HONORS.map((honor) => <article class="honor"><time datetime={String(honor.year)}>{honor.year}</time><h2>{locale.honors[honor.key]}</h2></article>)}
  </div>
)}

{section === 'global' && (
  <div class="global-track">
    {GLOBAL_IDS.map((id) => <article class="global-stop"><h2>{locale.global[id].title}</h2><p>{locale.global[id].body}</p></article>)}
  </div>
)}

{section === 'life' && (
  <article class="quiet-card"><h2>{locale.life.title}</h2><p>{locale.life.body}</p><p><small>{locale.common.verifiedFactsOnly}</small></p></article>
)}

{section === 'contact' && (
  <section class="contact-directory" aria-label={locale.nav.contact}>
    {contextContacts.length > 0 && <dl class="contact-context">{contextContacts.map((entry) => <div><dt>{locale.contact.fields[entry.key]}</dt><dd>{entry.value}</dd></div>)}</dl>}
    {directContacts.length > 0 && <ul class="contact-list">{directContacts.map((entry) => <li class="contact-entry">
      <div><span>{locale.contact.fields[entry.key]}</span>{entry.href ? <a class="contact-value" href={entry.href} target={entry.external ? '_blank' : undefined} rel={entry.external ? 'noopener noreferrer' : undefined}>{entry.external ? displayExternalValue(entry.value) : entry.value}</a> : <strong>{entry.value}</strong>}</div>
      <button type="button" class="contact-copy" data-copy-contact={entry.value} data-copied-label={locale.contact.copied}>{locale.contact.copy}</button>
    </li>)}</ul>}
    {cvDownloads.length > 0 && <div class="contact-downloads">{cvDownloads.map((entry) => <a class="button-outline" href={assetFor(entry.value)} download>{locale.contact.fields[entry.key]}</a>)}</div>}
    {directContacts.length > 0 && vcardExists && <div class="contact-actions"><a class="button-outline" href={assetFor(contact.vcardPath)} download>{locale.contact.save}</a></div>}
  </section>
)}

{section === 'contact' && <script is:inline>
  document.querySelectorAll('[data-copy-contact]').forEach((button) => button.addEventListener('click', async () => {
    const value = button.getAttribute('data-copy-contact') || '';
    if (!value) return;
    const original = button.textContent || '';
    try {
      if (!navigator.clipboard?.writeText) return;
      await navigator.clipboard.writeText(value);
      button.textContent = button.getAttribute('data-copied-label') || original;
      window.setTimeout(() => { button.textContent = original; }, 1600);
    } catch {
      button.textContent = original;
    }
  }));
</script>}

<footer class="page-footer">
  <a href={routeFor(lang)}>← {locale.common.back}</a>
  <span>Yihao Bian · {new Date().getFullYear()}</span>
</footer>
