---
import { LANGUAGE_NAMES, LANGUAGES } from '@/data/site';
import { routeFor } from '@/utils/routes';
---
<!doctype html>
<html lang="en" data-base={import.meta.env.BASE_URL}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index,follow" />
    <meta http-equiv="refresh" content={`2;url=${routeFor('en')}`} />
    <title>YIHAO NEXUS — Choose language</title>
    <style>html{color-scheme:dark;background:#061014;color:#edf5f2;font-family:system-ui,sans-serif}body{min-height:100vh;margin:0;display:grid;place-items:center;padding:1rem}main{text-align:center}h1{font-weight:300;letter-spacing:.12em}p{color:#a9bbb8}nav{display:flex;flex-wrap:wrap;justify-content:center;gap:.65rem;max-width:45rem;margin-top:2rem}a{color:#67d7c4;border:1px solid #25433f;border-radius:999px;padding:.7rem 1rem;text-decoration:none}</style>
    <script is:inline>
      (() => {
        const supported = ['en','zh-CN','ar','fr','ru','es','ja','ko'];
        const saved = localStorage.getItem('yihao-language');
        const raw = saved || navigator.language || 'en';
        const match = supported.find((code) => raw.toLowerCase() === code.toLowerCase()) || supported.find((code) => raw.toLowerCase().startsWith(code.split('-')[0].toLowerCase())) || 'en';
        localStorage.setItem('yihao-language', match);
        const base = document.documentElement.dataset.base || '/';
        window.location.replace(`${base}${base.endsWith('/') ? '' : '/'}${match}/`);
      })();
    </script>
  </head>
  <body><main><h1>YIHAO NEXUS</h1><p>Choose a language / 选择语言</p><nav>{LANGUAGES.map((lang) => <a lang={lang} dir={lang === 'ar' ? 'rtl' : 'ltr'} href={routeFor(lang)}>{LANGUAGE_NAMES[lang]}</a>)}</nav></main></body>
</html>
