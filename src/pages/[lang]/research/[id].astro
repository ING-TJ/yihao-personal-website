---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocale } from '@/content/locales';
import { getDetailLabels } from '@/content/detail';
import { ENABLED_LOCALES, RESEARCH_IDS, type Lang, type ResearchId } from '@/data/site';
import { publications } from '@/data/publications';
import { routeFor } from '@/utils/routes';
import '@/styles/detail.css';

export function getStaticPaths() {
  return ENABLED_LOCALES.flatMap((lang) => RESEARCH_IDS.map((id) => ({ params: { lang, id } })));
}

const lang = Astro.params.lang as Lang;
const id = Astro.params.id as ResearchId;
const locale = getLocale(lang);
const labels = getDetailLabels(lang);
const item = locale.research[id];
---
<BaseLayout lang={lang} section="research" path={`research/${id}`} title={item.title} description={item.description}>
  <article class="detail-page">
    <header class="detail-hero" data-reveal>
      <div class="detail-meta"><p class="eyebrow">{labels.research.eyebrow}</p><span>R / {String(RESEARCH_IDS.indexOf(id) + 1).padStart(2, '0')}</span></div>
      <div class="detail-title"><h1>{item.title}</h1><p>{item.description}</p></div>
    </header>

    <div class="detail-media" role="img" aria-label={`${item.title} editorial visual`} data-reveal>
      <span class="detail-media-index">R / {String(RESEARCH_IDS.indexOf(id) + 1).padStart(2, '0')}</span>
      <div class="detail-media-mark" aria-hidden="true"><i></i><i></i><i></i></div>
    </div>

    <section class="detail-block detail-question" data-reveal>
      <p class="detail-label">01 / {labels.research.questions}</p>
      <h2>{item.question}</h2>
    </section>

    <section class="detail-publications" data-reveal>
      <div><p class="detail-label">02 / {labels.research.publications}</p><h2>{labels.research.publications}</h2></div>
      {publications.length === 0 && <div class="detail-empty"><span>000</span><p>{locale.publications.emptyBody}</p></div>}
    </section>

    <footer class="detail-back"><a class="text-link" href={routeFor(lang, 'research')}>← {labels.research.back}</a></footer>
  </article>
</BaseLayout>
