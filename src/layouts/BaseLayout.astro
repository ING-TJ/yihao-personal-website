---
import '@/styles/global.css';
import { LANGUAGE_NAMES, LANGUAGES, SECTIONS, SITE, type Lang, type Section } from '@/data/site';
import { getLocale } from '@/content/locales';
import { routeFor } from '@/utils/routes';

interface Props {
  lang: Lang;
  section?: Section;
  title?: string;
  description?: string;
  immersive?: boolean;
}

const { lang, section, title, description, immersive = false } = Astro.props;
const locale = getLocale(lang);
const currentTitle = title ? `${title} — ${SITE.name}` : locale.meta.title;
const currentDescription = description ?? locale.meta.description;
const canonicalPath = `${lang}/${section ? `${section}/` : ''}`;
const canonical = new URL(canonicalPath, Astro.site);
const ogImage = new URL('og.png', Astro.site);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  alternateName: SITE.nameZh,
  url: new URL(lang + '/', Astro.site).href,
  affiliation: { '@type': 'CollegeOrUniversity', name: SITE.affiliation.name },
  founder: { '@type': 'Organization', name: SITE.organization.name },
  jobTitle: ['PhD Candidate', 'Researcher', 'Founder'],
};
---
<!doctype html>
<html lang={lang} dir={locale.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#061014" />
    <meta name="description" content={currentDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}icons/favicon-32.png`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />
    {LANGUAGES.map((code) => <link rel="alternate" hreflang={code} href={new URL(`${code}/${section ? `${section}/` : ''}`, Astro.site)} />)}
    <link rel="alternate" hreflang="x-default" href={new URL('en/', Astro.site)} />
    <meta property="og:type" content="profile" />
    <meta property="og:title" content={currentTitle} />
    <meta property="og:description" content={currentDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={currentTitle} />
    <meta name="twitter:description" content={currentDescription} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{currentTitle}</title>
  </head>
  <body class:list={{ immersive }} data-home={section ? routeFor(lang) : undefined}>
    <a class="sr-only" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="brand" href={routeFor(lang)} aria-label={`${SITE.concept} — ${locale.common.home}`}>
        <span class="brand-mark" aria-hidden="true"></span><span>{SITE.concept}</span>
      </a>
      <div class="header-tools">
        <details class="header-details">
          <summary aria-label={locale.common.menu}>{locale.common.menu}</summary>
          <nav class="header-popover" aria-label={locale.common.menu}>
            {SECTIONS.map((item) => <a href={routeFor(lang, item)} aria-current={section === item ? 'page' : undefined}>{locale.nav[item]}</a>)}
          </nav>
        </details>
        <details class="header-details">
          <summary aria-label={locale.common.language}>{LANGUAGE_NAMES[lang]}</summary>
          <nav class="header-popover" aria-label={locale.common.language}>
            {LANGUAGES.map((code) => <a data-language={code} lang={code} dir={code === 'ar' ? 'rtl' : 'ltr'} href={routeFor(code, section)} aria-current={code === lang ? 'page' : undefined}>{LANGUAGE_NAMES[code]}</a>)}
          </nav>
        </details>
      </div>
    </header>
    <main id="main"><slot /></main>
    <script is:inline>
      document.querySelectorAll('[data-language]').forEach((link) => link.addEventListener('click', () => localStorage.setItem('yihao-language', link.getAttribute('data-language') || 'en')));
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && document.body.dataset.home) window.location.assign(document.body.dataset.home);
      });
    </script>
  </body>
</html>
